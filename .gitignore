# OS
.DS_Store

# Environment files
.env*

# Node / package
**/node_modules
**/.pnp
**/.pnp.*

# Next.js / build
**/.next
**/out
**/build
**/.turbo

# Logs
**/npm-debug.log*
**/yarn-debug.log*
**/yarn-error.log*
**/.pnpm-debug.log*

# Vercel
**/.vercel

# Git worktrees (local clone paths; not part of the app)
.worktrees/

# Misc
.qodo/
Prut/web/.git.bak/
.vscode/
*.code-workspace

# Python tooling (crewai-ui-audit and similar helper tools)
**/.venv/
**/__pycache__/
**/*.py[cod]
**/*.egg-info/
**/.pytest_cache/
**/.mypy_cache/
**/.ruff_cache/

# Absolute-path leakage artifacts from tools that wrote to $HOME
# instead of cwd (e.g., a previous crewai run created a recursive
# Users/galsasson/Peirutech/... nesting inside the tool dir).
Prut/web/tools/*/Users/
