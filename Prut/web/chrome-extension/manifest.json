{
  "manifest_version": 3,
  "name": "Peroot - AI Prompt Enhancer",
  "version": "1.0.0",
  "description": "Enhance any prompt instantly with AI. Right-click to upgrade selected text or use the popup launcher. Supports Hebrew and English.",
  "homepage_url": "https://peroot.space",
  "permissions": [
    "contextMenus",
    "activeTab",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "https://peroot.space/*",
    "https://www.peroot.space/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    },
    "default_title": "Peroot - שדרוג פרומפטים"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Alt+P",
        "mac": "Alt+P"
      },
      "description": "Open Peroot popup"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://peroot.space/*",
        "https://www.peroot.space/*"
      ],
      "js": ["content/auth-sync.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
