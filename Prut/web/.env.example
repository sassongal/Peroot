# AI API Keys
GOOGLE_GENERATIVE_AI_API_KEY=your_google_ai_studio_api_key_here
GROQ_API_KEY=your_groq_api_key_here
# Used by the fallback chain (Mistral Small) — see src/lib/ai/models.ts
MISTRAL_API_KEY=your_mistral_api_key_here
# Optional: only if next.config CSP connect-src still lists DeepSeek for a future provider
# DEEPSEEK_API_KEY=

# Supabase (Public)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase (Private/Admin)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# Redis (Upstash recommended)
REDIS_URL=rediss://default:password@your-redis.upstash.io:6379

# Sentry (Monitoring)
SENTRY_DSN=https://your-dsn@sentry.io/1
NEXT_PUBLIC_SENTRY_DSN=https://your-dsn@sentry.io/1
SENTRY_AUTH_TOKEN=your-token-for-sourcemap-upload

# LemonSqueezy (Payments)
LEMONSQUEEZY_API_KEY=your_lemonsqueezy_api_key
LEMONSQUEEZY_STORE_ID=your_store_id
LEMONSQUEEZY_WEBHOOK_SECRET=your_webhook_signing_secret
NEXT_PUBLIC_LEMONSQUEEZY_VARIANT_ID=your_variant_id

# Analytics (PostHog)
NEXT_PUBLIC_POSTHOG_KEY=phc_your_posthog_key
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Google Analytics 4
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
GA4_PROPERTY_ID=123456789

# Google Search Console
NEXT_PUBLIC_GOOGLE_VERIFICATION=your_verification_token
GOOGLE_SEARCH_CONSOLE_SITE_URL=https://peroot.space

# Microsoft Clarity (session recording & heatmaps — free)
NEXT_PUBLIC_CLARITY_ID=your_clarity_project_id

# IndexNow (instant search indexing — free)
INDEXNOW_KEY=your_indexnow_key

# Google PageSpeed Insights (for /api/speed-test — free, requires API key)
GOOGLE_PAGESPEED_API_KEY=your_pagespeed_api_key

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=https://peroot.space
NEXT_PUBLIC_SITE_NAME=Peroot
MAINTENANCE_MODE=false
