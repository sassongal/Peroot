{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "bench:prompts": "node scripts/benchmark-prompts.mjs",
    "tailwind:canonicalize": "node scripts/canonicalize-tailwind-classes.mjs",
    "test:engines-live": "tsx scripts/test-engines-live.ts",
    "db:migrate": "tsx scripts/run-all-migrations.ts",
    "analyze": "ANALYZE=true next build",
    "knip": "knip",
